@model SmartNovel.Models.ViewModels.ProfileVM
@using SmartNovel.Helpers
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    Layout = "_Layout";
}
@section Styles {
    <link rel="stylesheet" href="~/css/account/index.css" asp-append-version="true" />
}
<div class="account-container">
    <h1 class="page-title">TÀI KHOẢN NGƯỜI DÙNG</h1>

    <div class="profile-wrapper">
        <div class="sidebar">
            <div class="profile-card">
                <div class="avatar-wrap d-inline-flex justify-content-center align-items-center">
                    @if (!string.IsNullOrEmpty(Model.User.AvartarUrl))
                    {
                        <img src="@Model.User.AvartarUrl" alt="Avatar">
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="#2d3142" class="bi bi-person" viewBox="0 0 16 16">
                            <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6m2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0m4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4m-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10s-3.516.68-4.168 1.332c-.678.678-.83 1.418-.832 1.664z" />
                        </svg>
                    }
                </div>
                <h2 class="username">@Model.User.Username</h2>
                <p class="role">
                    @(Model.User.RoleId switch
                    {
                        "1" => "Admin",
                        "2" => "Moderator",
                        "3" => "Author",
                        "4" => "Reader",
                        _ => "Unknown Role"
                    })
                </p>
            </div>

            @if (Model.User.RoleId == "3")
            {
                <div class="profile-stats">
                    <div class="stat-box">
                        <strong>@DisplayHelpers.FormatCompactNumber(Convert.ToInt32(ViewBag.FollowerCount ?? 0))</strong>
                        <span>Follower</span>
                    </div>

                    <div class="stat-box">
                        <strong>@DisplayHelpers.FormatCompactNumber(Convert.ToInt32(ViewBag.TotalNovelCount ?? 0))</strong>
                        <span>Tác phẩm</span>
                    </div>

                    <div class="stat-box">
                        <strong>@DisplayHelpers.FormatCompactNumber(Convert.ToInt32(ViewBag.TotalViewCount ?? 0))</strong>
                        <span>Lượt xem</span>
                    </div>

                    <div class="stat-box">
                        <strong>@DisplayHelpers.FormatCompactNumber(Convert.ToInt32(ViewBag.FollowAuthorCount ?? 0))</strong>
                        <span>Theo dõi </span>
                    </div>
                </div>
            }
            else if (Model.User.RoleId == "4")
            {
                <div class="profile-stats">
                    <div class="stat-box">
                        <strong>@DisplayHelpers.FormatCompactNumber(Convert.ToInt32(ViewBag.FollowerCount ?? 0))</strong>
                        <span>Follower</span>
                    </div>

                    <div class="stat-box">
                        <strong>@DisplayHelpers.FormatCompactNumber(Convert.ToInt32(ViewBag.FollowNovelCount ?? 0))</strong>
                        <span>Theo dõi truyện</span>
                    </div>

                    <div class="stat-box">
                        <strong>@DisplayHelpers.FormatCompactNumber(Convert.ToInt32(ViewBag.FollowAuthorCount ?? 0))</strong>
                        <span>Theo dõi </span>
                    </div>
                </div>
            }

            <div class="d-flex flex-column gap-2 mt-3">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <div class="d-flex flex-column gap-2 mt-3">

                        @if (Model.IsFollowing)
                        {
                            <form asp-controller="account"
                                  asp-action="UnFollowAuthor"
                                  method="post">

                                <input type="hidden"
                                       name="authorId"
                                       value="@Model.User.Uid" />

                                <button type="submit"
                                        class="btn btn-success w-100">

                                    <i class="bi bi-person-check-fill"></i>
                                    Đang theo dõi
                                </button>

                            </form>
                        }
                        else
                        {
                            <form asp-controller="account"
                                  asp-action="FollowAuthor"
                                  method="post">

                                <input type="hidden"
                                       name="authorId"
                                       value="@Model.User.Uid" />

                                <button type="submit"
                                        class="btn btn-primary w-100">

                                    <i class="bi bi-person-plus-fill"></i>
                                    Theo dõi
                                </button>

                            </form>
                        }

                        @if (Model.IsAuthorBlocked)
                        {
                            <form asp-controller="Novel"
                                  asp-action="UnBlockAuthor"
                                  method="post">

                                <input type="hidden"
                                       name="authorId"
                                       value="@Model.User.Uid" />

                                <button type="submit"
                                        class="btn btn-warning w-100">

                                    <i class="bi bi-person-slash-fill"></i>
                                    Bỏ chặn
                                </button>

                            </form>
                        }
                        else
                        {
                            <form asp-controller="Novel"
                                  asp-action="BlockAuthor"
                                  method="post">

                                <input type="hidden"
                                       name="authorId"
                                       value="@Model.User.Uid" />

                                <button type="submit"
                                        class="btn btn-danger w-100">

                                    <i class="bi bi-person-slash"></i>
                                    Chặn tác giả
                                </button>

                            </form>
                        }

                    </div>
                }
            </div>
        </div>

        <div class="content">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-dark-custom text-white py-3 rounded-top-3">
                    <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i> Thông tin người dùng</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <tbody>
                                <tr>
                                    <td class="col-label">UID</td>
                                    <td class="text-secondary fw-medium">@Model.User.Uid</td>
                                </tr>
                                <tr>
                                    <td class="col-label">Tên hiển thị</td>
                                    <td class="text-secondary fw-medium">@Model.User.DisplayName</td>
                                </tr>
                                <tr>
                                    <td class="col-label">Email</td>
                                    <td class="text-secondary fw-medium">@Model.User.Email</td>
                                </tr>
                                <tr>
                                    <td class="col-label">Ngày sinh</td>
                                    <td class="text-secondary fw-medium">
                                        @(Model.User.Birthday.HasValue ? Model.User.Birthday.Value.ToString("dd/MM/yyyy") : "Chưa cập nhật")
                                    </td>
                                </tr>
                                <tr>
                                    <td class="col-label border-bottom-0">Di động</td>
                                    <td class="text-secondary fw-medium border-bottom-0">@Model.User.Phone</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Danh sách hiển thị của tác giả-->
            @if (Model.User.RoleId == "3")
            {
                <!-- TÁC PHẨM CÔNG KHAI -->
                <div class="card shadow-sm border-0 rounded-3 mt-4">

                    <div class="card-header bg-dark-custom text-white py-3">
                        <h5 class="mb-0">
                            <i class="fas fa-book me-2"></i>
                            Tác phẩm công khai
                        </h5>
                    </div>

                    <div class="card-body">

                        @if (ViewBag.PublicNovels != null && ViewBag.PublicNovels.Count > 0)
                        {
                            <div class="row">

                                @foreach (Novel novel in ViewBag.PublicNovels)
                                {
                                    <div class="col-lg-3 col-md-4 col-sm-6 mb-4">

                                        <div class="card h-100 shadow-sm">

                                            <img src="@novel.ImageNovelUrl"
                                                 class="card-img-top"
                                                 alt="@novel.Title"
                                                 style="height:320px;object-fit:cover;">

                                            <div class="card-body d-flex flex-column">

                                                <h6 class="card-title">
                                                    @novel.Title
                                                </h6>

                                                <div class="text-muted small mb-2">

                                                    <span>
                                                        <i class="fas fa-eye me-1"></i>
                                                        @DisplayHelpers.FormatCompactNumber(novel.ViewCount ?? 0)
                                                    </span>

                                                    <span class="ms-3">
                                                        <i class="fas fa-heart text-danger me-1"></i>
                                                        @DisplayHelpers.FormatCompactNumber(novel.LikeCount ?? 0)
                                                    </span>

                                                </div>

                                                <a href="/truyen/@novel.NovelId"
                                                       class="btn btn-primary mt-auto">
                                                    Xem chi tiết
                                                </a>

                                            </div>

                                        </div>

                                    </div>
                                }

                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info mb-0">
                                Chưa có tác phẩm công khai.
                            </div>
                        }

                    </div>

                </div>

                <!-- TRUYỆN ĐANG THEO DÕI -->
                <div class="card shadow-sm border-0 rounded-3 mt-4">

                    <div class="card-header bg-dark-custom text-white py-3">
                        <h5 class="mb-0">
                            <i class="fas fa-bookmark me-2"></i>
                            Truyện đang theo dõi
                        </h5>
                    </div>

                    <div class="card-body">

                        @if (Model.User.Novels != null && Model.User.Novels.Any())
                        {
                            <div class="row">

                                @foreach (Novel novel in Model.User.Novels)
                                {
                                    <div class="col-lg-3 col-md-4 col-sm-6 mb-4">

                                        <div class="card h-100 shadow-sm">

                                            <img src="@novel.ImageNovelUrl"
                                                 class="card-img-top"
                                                 alt="@novel.Title"
                                                 style="height:320px;object-fit:cover;">

                                            <div class="card-body d-flex flex-column">

                                                <h6 class="card-title">
                                                    @novel.Title
                                                </h6>

                                                <a href="/truyen/@novel.NovelId"
                                                       class="btn btn-primary mt-auto">
                                                    Xem chi tiết
                                                </a>

                                            </div>

                                        </div>

                                    </div>
                                }

                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info mb-0">
                                Chưa theo dõi truyện nào.
                            </div>
                        }

                    </div>

                </div>

                <!-- NGƯỜI TÔI ĐANG THEO DÕI -->
                <div class="card shadow-sm border-0 rounded-3 mt-4">

                    <div class="card-header bg-dark-custom text-white py-3">
                        <h5 class="mb-0">
                            <i class="fas fa-user-edit me-2"></i>
                            Người tôi đang theo dõi
                        </h5>
                    </div>

                    <div class="card-body">

                        @if (ViewBag.FollowingAuthors != null && ViewBag.FollowingAuthors.Count > 0)
                        {
                            <div class="row">

                                @foreach (User author in ViewBag.FollowingAuthors)
                                {
                                    <div class="col-lg-3 col-md-4 col-sm-6 mb-4">

                                        <div class="card h-100 shadow-sm">

                                            <img src="@(string.IsNullOrEmpty(author.AvartarUrl) ? "/images/default-avatar.png" : author.AvartarUrl)"
                                                 class="card-img-top"
                                                 style="height:250px;object-fit:cover;">

                                            <div class="card-body text-center">

                                                <h6>@author.DisplayName</h6>

                                                <small class="text-muted d-block">
                                                    @("@" + author.Username)
                                                </small>

                                            </div>

                                        </div>

                                    </div>
                                }

                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info mb-0">
                                Chưa theo dõi tác giả nào.
                            </div>
                        }

                    </div>

                </div>

                <!-- NGƯỜI THEO DÕI TÔI -->
                <div class="card shadow-sm border-0 rounded-3 mt-4">

                    <div class="card-header bg-dark-custom text-white py-3">
                        <h5 class="mb-0">
                            <i class="fas fa-users me-2"></i>
                            Người theo dõi tôi
                        </h5>
                    </div>

                    <div class="card-body">

                        @if (ViewBag.Followers != null && ViewBag.Followers.Count > 0)
                        {
                            <div class="row">

                                @foreach (User user in ViewBag.Followers)
                                {
                                    <div class="col-lg-3 col-md-4 col-sm-6 mb-4">

                                        <div class="card h-100 shadow-sm">

                                            <img src="@(string.IsNullOrEmpty(user.AvartarUrl) ? "/images/default-avatar.png" : user.AvartarUrl)"
                                                 class="card-img-top"
                                                 style="height:250px;object-fit:cover;">

                                            <div class="card-body text-center">

                                                <h6>@user.DisplayName</h6>

                                                <small class="text-muted d-block">
                                                    @("@" + user.Username)
                                                </small>

                                            </div>

                                        </div>

                                    </div>
                                }

                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info mb-0">
                                Chưa có người theo dõi nào.
                            </div>
                        }

                    </div>

                </div>
            }
            <!-- Danh sách hiển thị của độc giả-->
            @if (Model.User.RoleId == "4")
            {
                <!-- TRUYỆN ĐANG THEO DÕI -->
                <div class="card shadow-sm border-0 rounded-3 mt-4">

                    <div class="card-header bg-dark-custom text-white py-3">
                        <h5 class="mb-0">
                            <i class="fas fa-bookmark me-2"></i>
                            Truyện đang theo dõi
                        </h5>
                    </div>

                    <div class="card-body">

                        @if (Model.User.Novels != null && Model.User.Novels.Any())
                        {
                            <div class="row">

                                @foreach (Novel novel in Model.User.Novels)
                                {
                                    <div class="col-lg-3 col-md-4 col-sm-6 mb-4">

                                        <div class="card h-100 shadow-sm">

                                            <img src="@novel.ImageNovelUrl"
                                                 class="card-img-top"
                                                 alt="@novel.Title"
                                                 style="height:320px;object-fit:cover;">

                                            <div class="card-body d-flex flex-column">

                                                <h6 class="card-title">
                                                    @novel.Title
                                                </h6>

                                                <a href="/truyen/@novel.NovelId"
                                                       class="btn btn-primary mt-auto">
                                                    Xem chi tiết
                                                </a>

                                            </div>

                                        </div>

                                    </div>
                                }

                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info mb-0">
                                Chưa theo dõi truyện nào.
                            </div>
                        }

                    </div>

                </div>

                <!-- NGƯỜI TÔI ĐANG THEO DÕI -->
                <div class="card shadow-sm border-0 rounded-3 mt-4">

                    <div class="card-header bg-dark-custom text-white py-3">
                        <h5 class="mb-0">
                            <i class="fas fa-user-edit me-2"></i>
                            Người tôi đang theo dõi
                        </h5>
                    </div>

                    <div class="card-body">

                        @if (ViewBag.FollowingAuthors != null && ViewBag.FollowingAuthors.Count > 0)
                        {
                            <div class="row">

                                @foreach (User author in ViewBag.FollowingAuthors)
                                {
                                    <div class="col-lg-3 col-md-4 col-sm-6 mb-4">

                                        <div class="card h-100 shadow-sm">

                                            <img src="@(string.IsNullOrEmpty(author.AvartarUrl) ? "/images/default-avatar.png" : author.AvartarUrl)"
                                                 class="card-img-top"
                                                 style="height:250px;object-fit:cover;">

                                            <div class="card-body text-center">

                                                <h6>@author.DisplayName</h6>

                                                <small class="text-muted d-block">
                                                    @("@" + author.Username)
                                                </small>

                                            </div>

                                        </div>

                                    </div>
                                }

                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info mb-0">
                                Chưa theo dõi tác giả nào.
                            </div>
                        }

                    </div>

                </div>

                <!-- NGƯỜI THEO DÕI TÔI -->
                <div class="card shadow-sm border-0 rounded-3 mt-4">

                    <div class="card-header bg-dark-custom text-white py-3">
                        <h5 class="mb-0">
                            <i class="fas fa-users me-2"></i>
                            Người theo dõi tôi
                        </h5>
                    </div>

                    <div class="card-body">

                        @if (ViewBag.Followers != null && ViewBag.Followers.Count > 0)
                        {
                            <div class="row">

                                @foreach (User user in ViewBag.Followers)
                                {
                                    <div class="col-lg-3 col-md-4 col-sm-6 mb-4">

                                        <div class="card h-100 shadow-sm">

                                            <img src="@(string.IsNullOrEmpty(user.AvartarUrl) ? "/images/default-avatar.png" : user.AvartarUrl)"
                                                 class="card-img-top"
                                                 style="height:250px;object-fit:cover;">

                                            <div class="card-body text-center">

                                                <h6>@user.DisplayName</h6>

                                                <small class="text-muted d-block">
                                                    @("@" + user.Username)
                                                </small>

                                            </div>

                                        </div>

                                    </div>
                                }

                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info mb-0">
                                Chưa có người theo dõi nào.
                            </div>
                        }

                    </div>

                </div>
            }
        </div>
    </div>
</div>