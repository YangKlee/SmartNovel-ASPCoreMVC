@model SmartNovel.Models.User
@section Styles {
    <link rel="stylesheet" href="~/css/account/index.css" asp-append-version="true" />
}
<div class="account-container">
    <h1 class="page-title">TÀI KHOẢN NGƯỜI DÙNG</h1>
    
    <div class="profile-wrapper">
        <div class="sidebar">
            <div class="profile-card">
                <div class="avatar-wrap d-inline-flex justify-content-center align-items-center">
                    @if (!string.IsNullOrEmpty(Model.AvartarUrl))
                    {
                        <img src="@Model.AvartarUrl" alt="Avatar">
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="#2d3142" class="bi bi-person" viewBox="0 0 16 16">
                            <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6m2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0m4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4m-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10s-3.516.68-4.168 1.332c-.678.678-.83 1.418-.832 1.664z" />
                        </svg>
                    }
                </div>
                <h2 class="username">@Model.Username</h2>
                <p class="role">@Model.RoleId</p>
            </div>

            <div class="d-flex flex-column gap-2 mt-3">
                <a asp-action="updateInfo" class="btn btn-dark-custom w-100 shadow-sm"><i class="fas fa-edit me-2"></i> Sửa thông tin</a>
                <a asp-action="ChangePassword" class="btn btn-dark-custom w-100 shadow-sm"><i class="fas fa-unlock-alt me-2"></i> Đổi mật khẩu</a>
                <a asp-action="ChangeEmail" class="btn btn-dark-custom w-100 shadow-sm"><i class="fas fa-envelope me-2"></i> Đổi Email</a>
            </div>
        </div>

        <div class="content">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-dark-custom text-white py-3 rounded-top-3">
                    <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i> Thông tin người dùng</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <tbody>
                                <tr>
                                    <td class="col-label">UID</td>
                                    <td class="text-secondary fw-medium">@Model.Uid</td>
                                </tr>
                                <tr>
                                    <td class="col-label">Tên hiển thị</td>
                                    <td class="text-secondary fw-medium">@Model.DisplayName</td>
                                </tr>
                                <tr>
                                    <td class="col-label">Email</td>
                                    <td class="text-secondary fw-medium">@Model.Email</td>
                                </tr>
                                <tr>
                                    <td class="col-label">Ngày sinh</td>
                                    <td class="text-secondary fw-medium">
                                        @(Model.Birthday.HasValue ? Model.Birthday.Value.ToString("dd/MM/yyyy") : "Chưa cập nhật")
                                    </td>
                                </tr>
                                <tr>
                                    <td class="col-label border-bottom-0">Di động</td>
                                    <td class="text-secondary fw-medium border-bottom-0">@Model.Phone</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>