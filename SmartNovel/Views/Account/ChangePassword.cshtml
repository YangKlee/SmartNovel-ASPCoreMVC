@model SmartNovel.Models.ViewModel.ChangePassword
@section Styles {
    <link rel="stylesheet" href="~/css/account/form-layout.css" asp-append-version="true" />
}
@if (ViewBag.Msg != null)
{
    if (ViewBag.Success == true)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Thành công!</strong> @ViewBag.Msg
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    else
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Lỗi!</strong> @ViewBag.Msg
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
}
<div class="account-container">
    <h1 class="page-title text-uppercase fw-bold mt-2" style="color: #2E2F3F; font-size: 28px;">ĐỔI MẬT KHẨU</h1>

    <div class="content-form">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header py-3 rounded-top-3">
                <h5 class="mb-0"><i class="fas fa-lock me-2"></i> Thiết lập mật khẩu mới</h5>
            </div>
            <div class="card-body p-4">
                
                <form asp-action="ChangePassword" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="OldPassword" class="form-label fw-bold" style="color: #2E2F3F;"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="fas fa-key text-muted"></i></span>
                            <input asp-for="OldPassword" type="password" class="form-control focus-custom" placeholder="Nhập mật khẩu hiện tại..." />
                        </div>
                        <span asp-validation-for="OldPassword" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label fw-bold" style="color: #2E2F3F;"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="fas fa-shield-alt text-muted"></i></span>
                            <input asp-for="NewPassword" type="password" class="form-control focus-custom" placeholder="Nhập mật khẩu mới..." />
                        </div>
                        <span asp-validation-for="NewPassword" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-bold" style="color: #2E2F3F;"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="fas fa-check-circle text-muted"></i></span>
                            <input asp-for="ConfirmPassword" type="password" class="form-control focus-custom" placeholder="Nhập lại mật khẩu mới..." />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="d-flex gap-2 justify-content-end border-top pt-3">
                        <a asp-action="Profile" class="btn btn-outline-secondary px-4 py-2 rounded-2">
                            <i class="fas fa-arrow-left me-2"></i> Quay lại
                        </a>
                        <button type="submit" class="btn px-4 py-2 rounded-2 text-white shadow-sm" style="background-color: #2E2F3F;">
                            <i class="fas fa-save me-2"></i> Cập nhật
                        </button>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}