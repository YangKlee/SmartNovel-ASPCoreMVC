@model SmartNovel.Models.ViewModel.ChapterManagermentViewModel
@{
    ViewData["Title"] = "Quản lý chương";
    Layout = "_LayoutAdmin";
}

<head>
    <link rel="stylesheet" href="~/css/chaptermanager/index.css" />
</head>

<div class="chapter-manager-container">
  <div class="header-section">
    <div style="display: flex; align-items: center; gap: 8px;">
      <a href="/NovelManagerment/Index" class="btn btn-outline-secondary" title="Quay lại">
        <i class="bi bi-arrow-left"></i>
      </a>
      <h2 class="page-title">Quản lý chương</h2>
    </div>
    <a asp-controller="ChapterManagerment" asp-action="Add" asp-route-id="@Model.SelectedNovelId" class="add-btn">
      <i class="bi bi-plus-lg"></i>
      Thêm chương mới
    </a>
  </div>


  @if (TempData["Success"] != null)
  {
      if ((bool)TempData["Success"] == true)
      {
          <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
              <i class="bi bi-check-circle-fill me-2"></i> @TempData["Msg"]
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
      }
      else
      {
          <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
              <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Msg"]
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
      }
  }

  <form method="get" asp-action="Index" id="filterForm">
      <div class="filter-section">
        <div class="novel-select-row">
          <span class="label">Chọn truyện:</span>
          <select class="form-select custom-field novel-select" asp-for="SelectedNovelId" onchange="this.form.submit()">
              @if (Model.Novels != null && Model.Novels.Any())
              {
                  foreach (var novel in Model.Novels)
                  {
                      <option value="@novel.NovelId">@novel.Title</option>
                  }
              }
              else
              {
                  <option value="">Chưa có truyện nào</option>
              }
          </select>
        </div>

        <div class="search-filter-row">
          <select class="form-select custom-field status-filter" asp-for="SelectedStatus" onchange="this.form.submit()">
              <option value="all">Tất cả trạng thái</option>
              <option value="public">Đã đăng</option>
              <option value="draft">Bản nháp</option>
              <option value="cancel">Đã gỡ</option>
          </select>

          <div class="input-group custom-field search-box">
              <input type="text" class="form-control" asp-for="Keyword" placeholder="Tìm kiếm theo tiêu đề hoặc nội dung....">
              <button class="btn btn-outline-secondary" type="submit">
                  <i class="bi bi-search"></i>
              </button>
          </div>
        </div>

        <div class="stats-row">
          <div class="stat-card total">
            <div class="stat-number">@(Model.SelectedNovel?.countChapter ?? 0)</div>
            <div class="stat-label">Tổng số chương</div>
          </div>
          <div class="stat-card public">
            <div class="stat-number">@(Model.SelectedNovel?.countChapterPublic ?? 0)</div>
            <div class="stat-label">Đã đăng</div>
          </div>
          <div class="stat-card draft">
            <div class="stat-number">@(Model.SelectedNovel?.countChapterDraft ?? 0)</div>
            <div class="stat-label">Bản nháp</div>
          </div>
          <div class="stat-card removed">
            <div class="stat-number">@(Model.SelectedNovel?.countChapterRemove ?? 0)</div>
            <div class="stat-label">Đã gỡ</div>
          </div>
        </div>
      </div>
  </form>

  <div class="chapter-list">
      @if (Model.chapters != null && Model.chapters.Any())
      {
          foreach (var chapter in Model.chapters)
          {
              @await Component.InvokeAsync("ChapterManagerItem", chapter)
          }
      }
      else
      {
          <div class="text-center py-5">
              <span class="text-muted">Chưa có chương nào cho truyện này</span>
          </div>
      }
  </div>

  @await Html.PartialAsync("/Views/Shared/PartialView/_Pagination2.cshtml", Model)
</div>
