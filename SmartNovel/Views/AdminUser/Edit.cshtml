@model SmartNovel.ViewModels.AdminUser.EditUserViewModel

@{
    ViewData["Title"] = "Chỉnh sửa người dùng";
    Layout = "_LayoutAdmin";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0 py-2"><i class="bi bi-pencil-square"></i> Chỉnh sửa thông tin</h4>
                </div>

                <div class="card-body p-4">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                    <form asp-controller="AdminUser" asp-action="Edit" method="post">

                        <input type="hidden" asp-for="Uid" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Họ và tên <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" asp-for="Displayname">
                                <span asp-validation-for="Displayname" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Tên đăng nhập</label>
                                <input type="text" class="form-control bg-light" asp-for="Username" readonly>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
                                <input type="email" class="form-control" asp-for="Email">
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Mật khẩu mới <span class="fw-normal text-muted">(Để trống nếu giữ nguyên)</span></label>
                                <input type="password" class="form-control" asp-for="NewPassword" placeholder="Nhập mật khẩu mới...">
                                <span asp-validation-for="NewPassword" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Phân quyền <span class="text-danger">*</span></label>
                                <select class="form-select" asp-for="RoleID">
                                    <option value="4">Độc giả</option>
                                    <option value="3">Tác giả</option>
                                    <option value="1">Quản trị viên</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Trạng thái <span class="text-danger">*</span></label>
                                <select class="form-select" asp-for="Status">
                                    <option value="Active">Hoạt động</option>
                                    <option value="Banned">Bị khóa</option>
                                </select>
                            </div>
                        </div>

                        <div class="mt-4 pt-3 border-top text-end">
                            <a asp-action="Index" class="btn btn-secondary me-2 px-4">Hủy</a>
                            <button type="submit" class="btn btn-warning px-4">Lưu thay đổi</button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>


    <partial name="_ValidationScriptsPartial" />
