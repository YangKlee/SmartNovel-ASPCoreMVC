@model List<SmartNovel.Models.ViewModel.HistoryViewModel>

@{
    ViewData["Title"] = "Lịch sử đọc truyện";
}

<style>
    .history-container {
        max-width: 800px;
        margin: 0 auto;
    }
    .history-card {
        transition: transform 0.2s, box-shadow 0.2s;
        border: 1px solid #e0e0e0;
        border-radius: 12px;
        overflow: hidden;
    }
    .history-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.08);
    }
    .novel-thumbnail {
        width: 90px;
        height: 120px;
        object-fit: cover;
        border-radius: 8px;
    }
    .history-time {
        font-size: 0.85rem;
        color: #6c757d;
        background-color: #f8f9fa;
        padding: 4px 10px;
        border-radius: 20px;
        display: inline-block;
    }
    .chapter-link {
        color: #0d6efd;
        text-decoration: none;
        font-weight: 500;
    }
    .chapter-link:hover {
        text-decoration: underline;
    }
    .novel-title-link {
        color: #212529;
        text-decoration: none;
        font-weight: bold;
        font-size: 1.15rem;
    }
    .novel-title-link:hover {
        color: #0d6efd;
    }
    .empty-history {
        text-align: center;
        padding: 50px 20px;
        color: #6c757d;
    }
    .empty-history i {
        font-size: 4rem;
        margin-bottom: 15px;
        color: #dee2e6;
    }
</style>

<div class="container mt-5 mb-5 history-container">
    <div class="d-flex align-items-center mb-4 pb-2 border-bottom">
        <i class="bi bi-clock-history fs-3 text-primary me-3"></i>
        <h2 class="mb-0 fw-bold">Lịch sử đọc truyện</h2>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="empty-history bg-light rounded-3">
            <i class="bi bi-journal-x"></i>
            <h4>Bạn chưa đọc truyện nào</h4>
            <p>Hãy khám phá các bộ truyện hấp dẫn và quay lại đây nhé!</p>
            <a href="/" class="btn btn-primary mt-3 px-4 rounded-pill">Khám phá ngay</a>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var item in Model)
            {
                var novel = item.history?.novelInfo;
                var chapter = item.history?.chapterView;

                if (novel == null || chapter == null) continue;

                <div class="card history-card">
                    <div class="card-body p-3 d-flex align-items-center">

                        <a href="/truyen/@novel.NovelId" class="flex-shrink-0 me-3">
                            <img src="@novel.ImageNovelUrl" alt="@novel.Title" class="novel-thumbnail shadow-sm" onerror="this.src='/images/default-novel.jpg'">
                        </a>


                        <div class="flex-grow-1 min-width-0">

                            <div class="mb-1 text-truncate">
                                <a href="/truyen/@novel.NovelId" class="novel-title-link">
                                    @novel.Title
                                </a>
                            </div>

                            <div class="mb-2 text-truncate">
                                Đang đọc: 
                                <a href="/truyen/@novel.NovelId/@chapter.ChapterId" class="chapter-link">
                                    <i class="bi bi-bookmark-fill text-warning me-1"></i>
                                    Chương @chapter.ChaperOrder: @chapter.ChapterTitle
                                </a>
                            </div>

                            <div class="history-time">
                                <i class="bi bi-clock me-1"></i>
                                @if (item.timeView.HasValue)
                                {
                                    @item.timeView.Value.ToString("dd/MM/yyyy HH:mm")
                                }
                                else
                                {
                                    <span>Không rõ thời gian</span>
                                }
                            </div>
                        </div>

                        <div class="ms-3 flex-shrink-0 d-none d-sm-block">
                            <a href="/truyen/@novel.NovelId/@chapter.ChapterId" class="btn btn-outline-primary rounded-pill px-4">
                                Đọc tiếp <i class="bi bi-arrow-right ms-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
