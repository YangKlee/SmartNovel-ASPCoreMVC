@{
    var currentYear = DateTime.Now.Year;
    var companyName = "NovelSphere Global";
}

<footer class="custom-footer">
    <div class="container-fluid px-4 px-md-5">
        <!-- Main Footer Row -->
        <div class="row align-items-start py-4">
            <!-- Brand -->
            <div class="col-lg-3 col-md-6 mb-3 mb-lg-0">
                <div class="d-flex align-items-center mb-2">
                    <div class="footer-logo me-2">
                        <i class="bi bi-book-half"></i>
                    </div>
                    <h5 class="footer-brand mb-0">SMART TRUYỆN</h5>
                </div>
                <p class="footer-slogan mb-1">Chữ chạm tim, tìm bình yên nhỏ</p>
                <p class="footer-copyright mb-0">&copy; @currentYear @companyName.</p>
            </div>

            <!-- Liên kết nhanh -->
            <div class="col-lg-3 col-md-6 mb-3 mb-lg-0">
                <h6 class="footer-heading">LIÊN KẾT NHANH</h6>
                <ul class="list-unstyled footer-links">
                    <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li><a asp-controller="FillNovel" asp-action="Search">Thể loại</a></li>
                    <li><a asp-controller="FillNovel" asp-action="Search">Tìm kiếm</a></li>
                    <li><a asp-controller="FillNovel" asp-action="Search">Tác giả</a></li>
                </ul>
            </div>

            <!-- Thông tin chung -->
            <div class="col-lg-3 col-md-6 mb-3 mb-lg-0">
                <h6 class="footer-heading">THÔNG TIN CHUNG</h6>
                <ul class="list-unstyled footer-links">
                    <li><a asp-controller="Info" asp-action="AboutUs">Về Chúng tôi</a></li>
                    <li><a asp-controller="Info" asp-action="Contact">Thông tin liên hệ</a></li>
                    <li><a asp-controller="Info" asp-action="TermsOfService">Điều khoản Dịch vụ</a></li>
                    <li><a asp-controller="Info" asp-action="PressRoom">Phòng Báo chí</a></li>
                </ul>
            </div>

            <!-- Social + Policy -->
            <div class="col-lg-3 col-md-6">
                <div class="social-icons d-flex gap-3 mb-3">
                    <a href="https://facebook.com" target="_blank" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                    <a href="https://discord.com" target="_blank" aria-label="Discord"><i class="bi bi-discord"></i></a>
                    <a href="https://instagram.com" target="_blank" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                    <a href="https://youtube.com" target="_blank" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
                </div>
                <div class="footer-policy">
                    <a asp-controller="Info" asp-action="PrivacyPolicy">Quyền riêng tư</a>
                    <span class="separator">|</span>
                    <a asp-controller="Info" asp-action="TermsOfService">Điều khoản</a>
                    <span class="separator">|</span>
                    <a asp-controller="Info" asp-action="PrivacyPolicy">Chính sách</a>
                </div>
            </div>
        </div>
    </div>
</footer>