<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartNovel</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SmartNovel.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"> <!--Link bootrap icon footer-->

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header class="main-header navbar navbar-expand-lg">
        <div class="container-fluid">
            <!-- Logo -->
            <a href="/" class="logo text-decoration-none">Logo</a>

            <!-- Thanh Điều Hướng (Nav links) -->
            <nav class="nav-links d-flex align-items-center">
                <a href="/" class="nav-item">
                    <i class="bi bi-house"></i> Trang chủ
                </a>

                <!-- Thể loại Dropdown -->
                <div class="dropdown nav-item">
                    <a href="#" class="dropdown-toggle nav-item" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-list-ul"></i> Thể loại <i class="bi bi-chevron-down ms-icon"></i>
                    </a>
                    <ul class="dropdown-menu ">
                        <li><a class="dropdown-item" href="/the-loai/hanh-dong">Hành động</a></li>
                        <li><a class="dropdown-item" href="/the-loai/tinh-cam">Tình cảm</a></li>
                    </ul>
                </div>

                <!-- Bảng xếp hạng Dropdown -->
                <div class="dropdown nav-item">
                    <a href="#" class="dropdown-toggle nav-item" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-bar-chart"></i> Bảng xếp hạng <i class="bi bi-chevron-down ms-icon"></i>
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="/top/ngay">Top Ngày</a></li>
                        <li><a class="dropdown-item" href="/top/thang">Top Tháng</a></li>
                    </ul>
                </div>

                <a href="/tim-truyen" class="nav-item">
                    <i class="bi bi-search"></i> Tìm truyện
                </a>
                <a href="/tac-gia" class="nav-item">
                    <i class="bi bi-people"></i> Tác giả
                </a>
            </nav>

            <!-- Phần Auth (Đăng nhập / Đăng ký / User Menu) -->
            @if (!User.Identity.IsAuthenticated)
            {
                <!-- Khi CHƯA đăng nhập -->
                <div class="auth-buttons">
                    <a href="/auth/Login" class="btn btn-login">Đăng nhập</a>
                    <a href="/auth/Regist" class="btn btn-register">Đăng ký</a>
                </div>
            }
            else
            {
                <!-- Khi ĐÃ đăng nhập (Thay thế cho Angular Material Menu bằng Bootstrap Dropdown) -->
                <div class="dropdown">
                    <button class="user-info btn dropdown-toggle border-0" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="/Account/Profile">Hồ sơ cá nhân</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form asp-area="" asp-controller="auth" asp-action="Logout" method="get" id="logoutForm">
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            }
        </div>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        @await Html.PartialAsync("_Footer")
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>