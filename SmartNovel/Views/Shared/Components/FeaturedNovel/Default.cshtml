@model SmartNovel.Models.Novel

@if (Model != null)
{
    <div class="hero-featured">
        <div class="hero-bg" style="background-image: url('@(string.IsNullOrEmpty(Model.ImageBanerNovelUrl) ? Model.ImageNovelUrl : Model.ImageBanerNovelUrl)');"></div>
        <div class="hero-overlay"></div>
        
        <div class="hero-content-wrapper">
            <div class="hero-text">
                <div class="hero-badge"><i class="bi bi-star-fill me-1"></i> Truyện Đề Cử</div>
                
                <h2 class="hero-title">
                    <a href="/truyen/@Model.NovelId" class="text-decoration-none">@Model.Title</a>
                </h2>
                
                <div class="hero-author">
                    <i class="bi bi-pen"></i> Tác giả: <span class="text-info">@(Model.UidNavigation?.DisplayName ?? "Ẩn danh")</span>
                </div>

                <div class="hero-meta">
                    <span><i class="bi bi-eye-fill"></i> @(Model.ViewCount ?? 0) lượt đọc</span>
                    <span><i class="bi bi-list-ol"></i> @Model.Chapters.Count chương</span>
                    <span class="d-flex align-items-center"><i class="bi bi-star-fill text-warning me-1"></i> @Model.AverageRating/5</span>
                </div>

                <div class="hero-genres">
                    @foreach (var cat in Model.Categories.Take(4))
                    {
                        <span class="badge">@cat.Name</span>
                    }
                    @if (!Model.Categories.Any())
                    {
                         <span class="badge">Chưa rõ</span>
                    }
                </div>

                <p class="hero-desc">
                    @(Model.Description?.Length > 280 ? Model.Description.Substring(0, 280) + "..." : (Model.Description ?? "Chưa có mô tả."))
                </p>

                <div class="hero-actions">
                    <a href="/truyen/@Model.NovelId" class="hero-btn">
                        <i class="bi bi-book-half"></i> Đọc ngay
                    </a>

                    @{
                        var lastChapter = Model.Chapters.OrderByDescending(c => c.CreateTime).FirstOrDefault();
                        if (lastChapter != null)
                        {
                            <a href="/truyen/@Model.NovelId/@lastChapter.ChapterId" class="hero-btn hero-btn-secondary">
                                <i class="bi bi-lightning-charge-fill text-warning"></i> Chương mới
                            </a>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
}