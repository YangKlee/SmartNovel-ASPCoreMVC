@model IEnumerable<SmartNovel.Models.Novel>

<div class="admin-recommend-sidebar card shadow-sm border-0 bg-white mb-4 mt-4">
    <div class="card-header bg-dark text-white py-2">
        <h6 class="fw-bold text-uppercase mb-0 fs-7">
            <i class="bi bi-people-fill me-2"></i>Top Tác Giả
        </h6>
    </div>
    <div class="card-body p-3">


        <div class="sidebar-list d-flex flex-column">
            @if (Model != null && Model.Any())
            {
                @foreach (var truyen in Model)
                {
                    <a href="/Novel/@truyen.Slug" class="sidebar-item d-flex justify-content-between align-items-center py-2 text-decoration-none">
                        <span class="novel-title-sidebar text-danger text-truncate pe-3">
                            @truyen.Title
                        </span>

                        <span class="novel-chapter-sidebar text-muted text-nowrap">
                            Ch. @truyen.Chapters.Count
                        </span>
                    </a>
                }
            }
            else
            {
                <div class="text-muted text-center py-3 text-xs">Hôm nay chưa có truyện đề cử.</div>
            }
        </div>
    </div>
</div>