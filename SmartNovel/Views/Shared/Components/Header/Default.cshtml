@using System.Security.Claims
@using SmartNovel.Models

@inject SmartTruyenDbContext _context

@model List<MenuNav>

<header class="main-header">

    <!-- Logo -->
    <a href="/" class="logo"><img style="width:100px; height: 100px" src="https://pub-20056e4912f440f08b3d40eea545f95f.r2.dev/smart-novel/res/Smart-removebg-preview.png" alt="Alternate Text" /></a>

    <!-- Menu công khai -->
    <nav class="nav-links">

        @foreach (var item in Model)
        {
            <div class="dropdown">

                <a class="nav-item"
                       href="@(item.UrlLink ?? "#")">

                    @if (!string.IsNullOrEmpty(item.IconBootstrap))
                    {
                        <i class="@item.IconBootstrap"></i>
                    }

                    <span>@item.Content</span>

                    @if (item.InverseParent.Any())
                    {
                        <i class="bi bi-chevron-down ms-icon"></i>
                    }

                </a>

                @if (item.InverseParent.Any())
                {
                    <div class="dropdown-menu">

                        @foreach (var child in item.InverseParent.OrderBy(x => x.Id))
                        {
                            <a href="@child.UrlLink">
                                @child.Content
                            </a>
                        }

                    </div>
                }

            </div>
        }

    </nav>

    @if (!User.Identity!.IsAuthenticated)
    {
        <div class="auth-buttons">

            <a href="/Auth/Login"
                   class="btn btn-login">
                Đăng nhập
            </a>

            <a href="/Auth/Register"
                   class="btn btn-register">
                Đăng ký
            </a>

        </div>
    }
    else
    {
        var roleId =
            User.FindFirst(ClaimTypes.Role)?.Value;
        var uid = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        var roleMenus = _context.MenuNavs
            .Where(x => x.RoleId == roleId)
            .OrderBy(x => x.Id)
            .ToList();
            
        var currentUser = _context.Users.FirstOrDefault(x => x.Uid == uid);

        <div class="user-dropdown">

            <button class="user-info d-flex align-items-center">

                @if (currentUser != null && !string.IsNullOrEmpty(currentUser.AvartarUrl))
                {
                    <img src="@currentUser.AvartarUrl" alt="Avatar" class="rounded-circle object-fit-cover shadow-sm" style="width: 32px; height: 32px;" />
                }
                else
                {
                    <i class="bi bi-person-circle fs-4"></i>
                }

                <div class="d-flex flex-column text-start ms-2 lh-sm">
                    <span class="fw-medium">
                        @User.Identity.Name
                    </span>
                    <span class="role text-secondary" style="font-size: 0.75rem;">
                        @(roleId switch
                        {
                            "1" => "Admin",
                            "2" => "Moderator",
                            "3" => "Author",
                            "4" => "Reader",
                            _ => "Unknown Role"
                        })
                    </span>
                </div>
            </button>

            <div class="user-dropdown-menu">

                @foreach (var item in roleMenus)
                {
                    <a href="@item.UrlLink">

                        @if (!string.IsNullOrEmpty(item.IconBootstrap))
                        {
                            <i class="@item.IconBootstrap"></i>
                        }

                        <span>@item.Content</span>

                    </a>
                }

            </div>

        </div>
    }

</header>