@model SmartNovel.Models.ViewModels.FollowingNovelVM

@{
    ViewData["Title"] = "Truyện theo dõi";
}

<div class="container mt-4">

    <h2 class="mb-4">
        <i class="bi bi-bookmark-heart-fill"></i>
        Truyện đang theo dõi
    </h2>

    @if (!Model.Novels.Any())
    {
        <div class="alert alert-info">
            Bạn chưa theo dõi truyện nào.
        </div>
    }
    else
    {
        <div class="row">

            @foreach (var novel in Model.Novels)
            {
                <div class="col-md-3 mb-4">

                    <div class="card h-100 shadow-sm">

                        <img src="@novel.ImageNovelUrl"
                             class="card-img-top"
                             style="height:350px;object-fit:cover;">

                        <div class="card-body">

                            <h5 class="card-title">
                                @novel.Title
                            </h5>

                            <p class="text-muted small">
                                @novel.UidNavigation.DisplayName
                            </p>

                            <a href="/truyen/@novel.NovelId"
                                   class="btn btn-primary">

                                Xem chi tiết

                            </a>

                        </div>
                    </div>

                </div>
            }

        </div>
    }

</div>