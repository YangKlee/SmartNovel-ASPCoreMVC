@model SmartNovel.Models.ViewModels.BlockedAuthorVM

@{
    ViewData["Title"] = "Tác giả đã chặn";
}

<div class="container mt-4">

    <h2 class="mb-4">
        <i class="bi bi-person-slash-fill"></i>
        Tác giả đã chặn
    </h2>

    @if (Model?.Authors != null && Model.Authors.Any())
    {
        <div class="row">

            @foreach (var author in Model.Authors)
            {
                <div class="col-md-4 mb-3">

                    <div class="card h-100 shadow-sm border-0">

                        <div class="card-body text-center">

                            <img src="@(string.IsNullOrEmpty(author.AvartarUrl)
                                                                                                         ? "/images/default-avatar.png"
                                                                                                         : author.AvartarUrl)"
                                 class="rounded-circle mb-3 border"
                                 width="90"
                                 height="90"
                                 alt="avatar" />

                            <h5 class="mb-1">
                                @author.DisplayName
                            </h5>

                            <p class="text-muted mb-3">
                                @author.Username
                            </p>

                            <form asp-action="UnBlockAuthor" method="post">
                                <input type="hidden" name="authorId" value="@author.Uid" />

                                <button type="submit" class="btn btn-outline-danger w-100">
                                    <i class="bi bi-person-check-fill"></i>
                                    Bỏ chặn
                                </button>
                            </form>

                        </div>

                    </div>

                </div>
            }

        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            Bạn chưa chặn tác giả nào.
        </div>
    }

</div>