@model SmartNovel.Models.ViewModels.ReadNovelVM

@{
    ViewData["Title"] = Model.ChapterTitle;
}
<link rel="stylesheet" href="~/css/readnovel.css" asp-append-version="true" />
<div class="reading-background">

    <div class="reading-paper">

        <div class="reading-header">

            <div class="title-container">

                <h1 class="novel-title">
                    @Model.NovelTitle
                </h1>

                <h2 class="chapter-title">
                    Chương @Model.ChapterOrder:
                    @Model.ChapterTitle
                </h2>

            </div>

        </div>
        <div class="d-flex justify-content-center gap-2 mb-3">

            <button id="btnRead" class="btn btn-dark btn-sm">
                <i class="bi bi-volume-up"></i> Đọc
            </button>

            <button id="btnPause" class="btn btn-warning btn-sm">
                <i class="bi bi-pause-fill"></i> Tạm dừng
            </button>

            <button id="btnResume" class="btn btn-success btn-sm">
                <i class="bi bi-play-fill"></i> Tiếp tục
            </button>

            <button id="btnStop" class="btn btn-danger btn-sm">
                <i class="bi bi-stop-fill"></i> Dừng
            </button>

        </div>
        <hr />

        <div class="reading-content">

            @Html.Raw(Model.HtmlContent)

        </div>

        <div class="chapter-navigation">

            @if (Model.PrevChapterId != null)
            {
                <a class="nav-btn"
                       asp-action="Read"
                       asp-route-novelId="@Model.NovelId"
                       asp-route-chapterId="@Model.PrevChapterId">

                    ← Chương trước
                </a>
            }

            @if (Model.NextChapterId != null)
            {
                <a class="nav-btn"
                       asp-action="Read"
                       asp-route-novelId="@Model.NovelId"
                       asp-route-chapterId="@Model.NextChapterId">

                    Chương sau →
                </a>
            }
         
        </div>
        </div>
</div>
@section Scripts {
    <script>

        let speech = null;
        let voices = [];

        /* =========================
           LOAD VOICES (QUAN TRỌNG)
        ========================= */
        function loadVoices() {
            voices = speechSynthesis.getVoices();
        }

        loadVoices();
        speechSynthesis.onvoiceschanged = loadVoices;

        /* =========================
           LẤY GIỌNG VIỆT
        ========================= */
        function getVietnameseVoice() {
            if (!voices || voices.length === 0) return null;

            // 1. Ưu tiên số 1: Giọng tự nhiên/AI (Neural, Natural) của Microsoft hoặc Google xịn
            let premiumVoice = voices.find(v =>
                (v.lang === "vi-VN" || v.lang.includes("vi")) &&
                (v.name.toLowerCase().includes("natural") || v.name.toLowerCase().includes("neural") || v.name.toLowerCase().includes("google"))
            );
            if (premiumVoice) return premiumVoice;

            // 2. Ưu tiên số 2: Giọng Tiếng Việt bất kỳ chuẩn mã vi-VN
            let standardVoice = voices.find(v => v.lang === "vi-VN");
            if (standardVoice) return standardVoice;

            // 3. Fallback: Có chữ "vi" là hốt đại
            return voices.find(v => v.lang.toLowerCase().includes("vi")) || null;
        }

        /* =========================
           LẤY NỘI DUNG
        ========================= */
        function getContent() {
            let text = document.querySelector('.reading-content')?.innerText || '';

            // làm sạch text cho dễ đọc hơn
            return text
                .replace(/\s+/g, ' ')
                .replace(/\n/g, ' ')
                .trim();
        }

        /* =========================
           ĐỌC TRUYỆN
        ========================= */
        document.getElementById('btnRead').addEventListener('click', () => {

            speechSynthesis.cancel();

            const text = getContent();

            speech = new SpeechSynthesisUtterance(text);

            speech.lang = 'vi-VN';

            // lấy voice tiếng Việt nếu có
            const voice = getVietnameseVoice();
            if (voice) {
                speech.voice = voice;
            }

            // chỉnh để rõ hơn
            speech.rate = 0.95;   // chậm lại cho rõ chữ
            speech.pitch = 1;
            speech.volume = 1;

            speechSynthesis.speak(speech);
        });

        /* =========================
           TẠM DỪNG
        ========================= */
        document.getElementById('btnPause').addEventListener('click', () => {
            speechSynthesis.pause();
        });

        /* =========================
           TIẾP TỤC
        ========================= */
        document.getElementById('btnResume').addEventListener('click', () => {
            speechSynthesis.resume();
        });

        /* =========================
           DỪNG HẲN
        ========================= */
        document.getElementById('btnStop').addEventListener('click', () => {
            speechSynthesis.cancel();
        });

    </script>
}
}