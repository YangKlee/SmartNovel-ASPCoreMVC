@model SmartNovel.Models.ViewModels.ReadNovelVM

@{
    ViewData["Title"] = Model.ChapterTitle;
}

<link rel="stylesheet" href="~/css/readnovel.css" asp-append-version="true" />
<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">

<div class="reading-background">
    <div class="reading-paper">

        <!-- HEADER -->
        <div class="reading-header">
            <div class="title-container">

                <h1 class="novel-title">
                    @Model.NovelTitle
                </h1>

                <h2 class="chapter-title">
                    Chương @Model.ChapterOrder: @Model.ChapterTitle
                </h2>

            </div>
        </div>

        <!-- CONTROL BUTTONS  AUDIO-->
        <div class="d-flex justify-content-center gap-2 mb-3">
            <button id="btnRead" class="btn btn-dark btn-sm">
                <i class="bi bi-volume-up"></i> Đọc
            </button>

            <button id="btnPause" class="btn btn-warning btn-sm">
                <i class="bi bi-pause-fill"></i> Tạm dừng
            </button>

            <button id="btnResume" class="btn btn-success btn-sm">
                <i class="bi bi-play-fill"></i> Tiếp tục
            </button>

            <button id="btnStop" class="btn btn-danger btn-sm">
                <i class="bi bi-stop-fill"></i> Dừng
            </button>
        </div>
        <!-- CONTROL TITLE-->
        <div class="chapter-top-nav">

            <a asp-action="Detail"
                   asp-route-novelId="@Model.NovelId"
                   class="chapter-breadcrumb">

                @Model.NovelTitle
            </a>

            <span class="chapter-separator">
                <i class="bi bi-chevron-right"></i>
            </span>

            <span class="chapter-current-title">
                Chương @Model.ChapterOrder. @Model.ChapterTitle
            </span>

            <div class="chapter-actions">

                <button class="chapter-link"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#tocContainer">
                    Mục lục
                </button>

                @if (Model.NextChapterId != null)
                {
                    <a asp-action="Read"
                           asp-route-novelId="@Model.NovelId"
                           asp-route-chapterId="@Model.NextChapterId"
                           class="chapter-link">

                        Chương sau
                        <i class="bi bi-chevron-right"></i>

                    </a>
                }

            </div>

        </div>

        <!-- CONTENT -->
        <div class="reading-content ql-snow">
            <div class="ql-editor" style="padding: 0; font-family: inherit; font-size: inherit; line-height: inherit;">
                @Html.Raw(Model.HtmlContent)
            </div>
        </div>

        <!-- NAVIGATION -->
        <div class="chapter-navigation">

            @if (Model.PrevChapterId != null)
            {
                <a class="nav-btn"
                       asp-action="Read"
                       asp-route-novelId="@Model.NovelId"
                       asp-route-chapterId="@Model.PrevChapterId">
                    ← Chương trước
                </a>
            }

            <button class="nav-btn"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#tocContainer"
                    aria-expanded="false"
                    aria-controls="tocContainer">
                📖 Mục lục
            </button>

            @if (Model.NextChapterId != null)
            {
                <a class="nav-btn"
                       asp-action="Read"
                       asp-route-novelId="@Model.NovelId"
                       asp-route-chapterId="@Model.NextChapterId">
                    Chương sau →
                </a>
            }

        </div>



<!-- DANH SÁCH CHƯƠNG -->
<div class="collapse mt-3" id="tocContainer">

    <div class="toc-card">

        <div class="toc-header">
            <i class="bi bi-list-ul"></i>
            Danh sách chương
        </div>

        <div class="toc-list">

            @foreach (var chapter in Model.AllChapters)
            {
                var active = chapter.ChapterId == Model.ChapterId
                    ? "active-chapter"
                    : "";

                <a asp-action="Read"
                       asp-route-novelId="@Model.NovelId"
                       asp-route-chapterId="@chapter.ChapterId"
                       class="toc-item @active">

                    Chương @chapter.ChaperOrder:
                    @chapter.ChapterTitle

                </a>
            }

        </div>

    </div>

</div>
    </div>
</div>

<div class="container my-5" style="max-width: 900px;">
    <div class="comments-section p-4 bg-white shadow-sm" style="border-radius: 12px;">
        <h4 class="mb-4 fw-bold" style="color: #2c3e50;"><i class="bi bi-chat-left-text text-primary me-2"></i> Bình luận (@(Model.Comments?.Count ?? 0))</h4>

        @if (User.Identity.IsAuthenticated)
        {
            <form asp-controller="Novel" asp-action="AddComment" method="post" class="mb-5">
                <input type="hidden" name="ChapterId" value="@Model.ChapterId" />
                <input type="hidden" name="NovelId" value="@Model.NovelId" />
                <div class="form-group position-relative">
                    <textarea name="Content" class="form-control bg-light" rows="3" placeholder="Nhập bình luận của bạn về chương này..." required style="border-radius: 12px; padding: 15px; resize: none; border: 1px solid #e0e0e0;"></textarea>
                </div>
                <div class="mt-3 text-end">
                    <button type="submit" class="btn btn-primary px-4 py-2" style="border-radius: 8px; font-weight: 500; background-color: #44444E; border: none;">
                        <i class="bi bi-send me-1"></i> Gửi bình luận
                    </button>
                </div>
            </form>
        }
        else
        {
            <div class="alert alert-secondary text-center mb-5" style="border-radius: 12px;">
                Vui lòng <a href="/Auth/Login" class="fw-bold text-decoration-none" style="color: #44444E;">đăng nhập</a> để tham gia bình luận.
            </div>
        }

        <!-- Comments List -->
        <div class="comments-list mt-2">
            @if (Model.Comments != null && Model.Comments.Any())
            {
                foreach (var comment in Model.Comments.OrderByDescending(c => c.TimeCommeny))
                {
                    @await Component.InvokeAsync("Comment", new { model = comment })
                }
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-chat-square-dots text-muted" style="font-size: 3rem; opacity: 0.5;"></i>
                    <p class="text-muted mt-1 mb-0">Chưa có bình luận nào. Hãy là người đầu tiên bình luận!</p>
                </div>
            }
        </div>
    </div>
</div>
@section Scripts {
    <script>

        let speech = null;
        let voices = [];
        // LOAD VOICES 
        function loadVoices() {
            voices = speechSynthesis.getVoices();
        }

        loadVoices();
        if (speechSynthesis.onvoiceschanged !== undefined) {
            speechSynthesis.onvoiceschanged = loadVoices;
        }

        // ƯU TIÊN GIỌNG VIỆT NAM
        function getVietnameseVoice() {
            // Lấy danh sách giọng đọc mới nhất
            let currentVoices = speechSynthesis.getVoices();
            if (currentVoices.length > 0) {
                voices = currentVoices;
            }
            if (!voices || voices.length === 0) return null;

            // Lọc tất cả giọng đọc tiếng Việt dựa vào lang hoặc tên
            let viVoices = voices.filter(v => 
                (v.lang && v.lang.toLowerCase().includes("vi")) ||
                (v.name && v.name.toLowerCase().includes("vietnamese")) ||
                (v.name && v.name.toLowerCase().includes("việt nam"))
            );
            
            if (viVoices.length === 0) return null;

            // 1. Google voice (ưu tiên)
            let googleVoice = viVoices.find(v => v.name.toLowerCase().includes("google"));
            if (googleVoice) return googleVoice;

            // 2. Giọng natural / neural / online (Edge/Windows)
            let premiumVoice = viVoices.find(v =>
                v.name.toLowerCase().includes("natural") ||
                v.name.toLowerCase().includes("neural") ||
                v.name.toLowerCase().includes("online") ||
                v.name.toLowerCase().includes("hoaimy") ||
                v.name.toLowerCase().includes("namminh")
            );
            if (premiumVoice) return premiumVoice;

            // 3. Lấy giọng tiếng Việt đầu tiên tìm thấy
            return viVoices[0];
        }

        // LẤY NỘI DUNG TEXT
        function getContent() {
            const el = document.querySelector('.reading-content');
            if (!el) return "";

            return el.innerText
                .replace(/\s+/g, ' ')
                .replace(/\n/g, ' ')
                .trim();
        }

        // ĐỌC
        document.getElementById('btnRead').addEventListener('click', () => {

            speechSynthesis.cancel();

            const text = getContent();

            if (!text) return;

            speech = new SpeechSynthesisUtterance(text);

            speech.lang = 'vi-VN';

            const voice = getVietnameseVoice();
            if (voice) {
                speech.voice = voice;
            } else {
                alert("Máy của bạn chưa có sẵn giọng đọc Tiếng Việt, hoặc trình duyệt tải chưa xong. \n\nVui lòng sử dụng trình duyệt Microsoft Edge, hoặc vào cài đặt Windows (Settings > Time & Language > Speech) để thêm giọng Tiếng Việt (Vietnamese TTS) nhé!");
                return; // Ngừng đọc để tránh phát ra tiếng Anh
            }

            speech.rate = 0.95;
            speech.pitch = 1;
            speech.volume = 1;

            speechSynthesis.speak(speech);
        });

        // TẠM DỪNG
        document.getElementById('btnPause').addEventListener('click', () => {
            speechSynthesis.pause();
        });

        // TIẾP TỤC
        document.getElementById('btnResume').addEventListener('click', () => {
            speechSynthesis.resume();
        });

        // DỪNG HẲN
        document.getElementById('btnStop').addEventListener('click', () => {
            speechSynthesis.cancel();
        });

    </script>
}