@{
    ViewData["Title"] = "Quản lý bình luận";
    Layout = "_LayoutAdmin";
}
@model SmartNovel.Models.ViewModel.CommentManagermentViewModel
<head>
    <link rel="stylesheet" href="~/css/CommentReader.css" />
</head>
<div class="comment-reader-wrapper">
    <!-- Hiển thị thông báo (Thành công / Thất bại) từ TempData -->
    @if (TempData["Success"] != null)
    {
        if ((bool)TempData["Success"] == true)
        {
            <div class="alert alert-success alert-dismissible fade show mt-3 mb-0" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["Msg"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        else
        {
            <div class="alert alert-danger alert-dismissible fade show mt-3 mb-0" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Msg"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
    }

    <div class="comment-header">
        <h1 class="comment-title">Quản lý bình luận</h1>
    </div>

    <form method="get" asp-action="Index" id="filterForm">
        <div class="comment-controls">
            <input type="text" class="search-input w-100" asp-for="Keyword" placeholder="Nhập từ khóa nội dung, username hoặc tên hiển thị để tìm kiếm..." style="max-width: none;">
            <button type="submit" class="btn btn-primary ms-2">Tìm kiếm</button>
        </div>
    </form>

    <div class="comment-list mt-4">
        @if (Model.Comments != null && Model.Comments.Any())
        {
            foreach (var comment in Model.Comments)
            {
                <div class="comment-item-wrapper position-relative">
                    @await Component.InvokeAsync("CommentItemDashboard", new { model = comment })
                    @if (User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value == "1" || User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value == "2")
                    {
                        <form asp-controller="CommentManagerment" asp-action="Delete" asp-route-id="@comment.CommentId" method="post" class="position-absolute" style="top: 15px; right: 15px; z-index: 10;" onsubmit="return confirm('Bạn có chắc chắn muốn xóa bình luận này?');">
                            <button type="submit" class="btn btn-sm btn-danger" title="Xóa bình luận">
                                <i class="bi bi-trash"></i> Xóa
                            </button>
                        </form>
                    }
                </div>
            }
        }
        else if (!string.IsNullOrEmpty(Model.Keyword))
        {
            <span class="empty-noti">Không tìm thấy bình luận nào phù hợp với từ khóa.</span>
        }
        else
        {
            <span class="empty-noti">Nhập từ khóa và bấm Tìm kiếm để bắt đầu.</span>
        }
    </div>
</div>
@if (Model.TotalPage > 1)
{
    @await Html.PartialAsync("/Views/Shared/PartialView/_PaginationComment.cshtml", Model)
}
