@model SmartNovel.ViewModels.NovelSearchViewModel

@{
    ViewData["Title"] = "Tìm truyện";
}

<link rel="stylesheet" href="~/css/novel-search.css" />

<div class="container mt-4">
    <div class="search-panel">
        <h2>Tìm Truyện</h2>

        <form method="get" class="row g-2">
            <div class="col-md-4">
                <input class="form-control" name="keyword" value="@Model.Keyword" placeholder="Tên truyện..." />
            </div>
            <div class="col-md-3">
                <select class="form-select" name="authorId">
                    <option value="">Tất cả tác giả</option>
                    @foreach (var author in Model.Authors)
                    {
                        <option value="@author.Uid" selected="@(Model.AuthorId == author.Uid)">@author.DisplayName</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <select class="form-select" name="minRating">
                    <option value="">Mọi đánh giá</option>
                    @for (int i = 5; i >= 1; i--)
                    {
                        <option value="@i" selected="@(Model.MinRating == i)">⭐ @i sao trở lên</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Tìm kiếm</button>
            </div>
            <hr />
            <h5>Thể loại</h5>
            <div class="category-grid">
                @foreach (var category in Model.Categories)
                {
                    <label class="tag-item">
                        <input type="checkbox" name="selectedCategories" value="@category.CategoryId"
                               checked="@(Model.SelectedCategories.Contains(category.CategoryId))" />
                        @category.Name
                    </label>
                }
            </div>
        </form>
    </div>

   @if (Model.IsSearching)
{
    <div class="row mt-4">
        @if (Model.Novels.Any())
        {
            @foreach (var novel in Model.Novels)
            {
                <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                    <div class="novel-card">
                        <img src="@(string.IsNullOrEmpty(novel.ImageNovelUrl) ? "/images/no-image.png" : novel.ImageNovelUrl)" alt="@novel.Title" />
                        <div class="content">
                            <h5>@novel.Title</h5>
                            <small class="text-muted d-block mb-2">@novel.UidNavigation?.DisplayName</small>
                            
                            <div class="novel-stats">
                                <span>👁 @novel.ViewCount</span>
                                <span>❤ @novel.LikeCount</span>
                            </div>
                            <a href="/truyen/@novel.NovelId" class="btn btn-primary w-100 mt-3 rounded-3 text-decoration-none fw-bold">Đọc truyện</a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-warning">Không tìm thấy truyện phù hợp với từ khóa đã nhập.</div>
            </div>
        }
    </div>
}
    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link"
                           asp-action="Search"
                           asp-route-page="@i"
                           asp-route-keyword="@Model.Keyword"
                           asp-route-authorId="@Model.AuthorId"
                           asp-route-minRating="@Model.MinRating"
                           asp-route-selectedCategories="@(Model.SelectedCategories != null ? string.Join(",", Model.SelectedCategories) : "")">
                            @i
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
   
</div>