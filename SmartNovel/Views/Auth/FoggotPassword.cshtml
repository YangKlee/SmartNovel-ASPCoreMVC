@{
    Layout = "_authLayout";
    ViewData["Title"] = "Khôi phục mật khẩu";
}

@model SmartNovel.Models.ViewModel.ForgotPasswordViewModel

<div class="auth-overlay">
    <div class="auth-card">
        <a asp-controller="Auth" asp-action="Login" class="auth-close-btn" aria-label="Close" style="text-decoration: none;">X</a>

        <div class="auth-header">
            <h2>KHÔI PHỤC MẬT KHẨU</h2>
            <p>Nhập email của bạn để nhận liên kết đặt lại mật khẩu</p>
        </div>

        <form asp-controller="Auth" asp-action="SendEmailRecoveryPassword" method="post" novalidate>
            
            <div class="form-group">
                <label asp-for="txtEmail">EMAIL CỦA BẠN</label>
                <div class="input-wrapper">
                    <span class="icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M.05 3.555A2 2 0 0 1 2 2h12a2 2 0 0 1 1.95 1.555L8 8.414zM0 4.697v7.104l5.803-3.558zM6.761 8.83l-6.57 4.027A2 2 0 0 0 2 14h12a2 2 0 0 0 1.808-1.144l-6.57-4.027L8 9.586zm3.436-.586L16 11.801V4.697z" />
                        </svg>
                    </span>
                    <input type="email" asp-for="txtEmail" placeholder="example@gmail.com">
                </div>
                <span asp-validation-for="txtEmail" class="error-msg" style="color: #ef4444; font-size: 0.85rem; margin-top: 5px; display: block;"></span>
            </div>

            @if (ViewBag.Success != null && ViewBag.Success)
            {
                <div class="alert alert-success" style="color: #10b981; margin-bottom: 15px; text-align: center; font-size: 0.9rem;">
                    @ViewBag.Msg
                </div>
            }

            @if (ViewBag.Success != null && !ViewBag.Success)
            {
                <div class="alert alert-danger" style="color: #ef4444; margin-bottom: 15px; text-align: center; font-size: 0.9rem;">
                    @ViewBag.Msg
                </div>
            }

            <button type="submit" class="submit-btn">GỬI YÊU CẦU</button>
        </form>

        <div class="auth-footer">
            Nhớ mật khẩu rồi? <a asp-controller="Auth" asp-action="Login">Quay lại đăng nhập</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}