@{
    Layout = "_authLayout";
    ViewData["Title"] = "Đăng ký tài khoản";
}

@* Giả định bạn có một ViewModel tương ứng *@
@model SmartNovel.Models.ViewModel.RegisterViewModel
@if (ViewBag.Status != null || ViewBag.Status == true)
{
    <script>alter('@ViewBag.Msg')</script>
}
<div class="auth-overlay">
    <div class="auth-card">
        <a asp-controller="Home" asp-action="Index" class="auth-close-btn" aria-label="Close">X</a>

        <div class="auth-header">
            <h2>ĐĂNG KÝ TÀI KHOẢN</h2>
            <p>Tham gia với chúng tôi ngay hôm nay</p>
        </div>

        <form asp-controller="Auth" asp-action="Regist" method="post" novalidate>

            <div class="form-group">
                <label asp-for="txtUsername">TÊN TÀI KHOẢN</label>
                <div class="input-wrapper">
                    <span class="icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6m2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0m4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4m-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10c-2.29 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664z" />
                        </svg>
                    </span>
                    <input type="text" asp-for="txtUsername" placeholder="Nhập tên tài khoản">
                </div>
                <span asp-validation-for="txtUsername" class="error-msg" style="color: #ef4444; font-size: 0.85rem; margin-top: 5px; display: block;"></span>
            </div>

            <div class="form-group">
                <label asp-for="txtEmail">EMAIL</label>
                <div class="input-wrapper">
                    <span class="icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M.05 3.555A2 2 0 0 1 2 2h12a2 2 0 0 1 1.95 1.555L8 8.414zM0 4.697v7.104l5.803-3.558zM6.761 8.83l-6.57 4.027A2 2 0 0 0 2 14h12a2 2 0 0 0 1.808-1.144l-6.57-4.027L8 9.586zm3.436-.586L16 11.801V4.697z" />
                        </svg>
                    </span>
                    <input type="email" asp-for="txtEmail" placeholder="example@gmail.com">
                </div>
                <span asp-validation-for="txtEmail" class="error-msg" style="color: #ef4444; font-size: 0.85rem; margin-top: 5px; display: block;"></span>
            </div>

            <div class="form-group">
                <label asp-for="txtDisplayName">TÊN HIỂN THỊ</label>
                <div class="input-wrapper">
                    <span class="icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2z" />
                            <path d="M4.5 9h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1 0-1m0-3h7a.5.5 0 0 1 0 1h-7a.5.5 0 0 1 0-1m0-3h7a.5.5 0 0 1 0 1h-7a.5.5 0 0 1 0-1" />
                        </svg>
                    </span>
                    <input type="text" asp-for="txtDisplayName" placeholder="Tên hiển thị">
                </div>
                <span asp-validation-for="txtDisplayName" class="error-msg" style="color: #ef4444; font-size: 0.85rem; margin-top: 5px; display: block;"></span>
            </div>

            <div class="form-group">
                <label asp-for="txtPhone">SỐ ĐIỆN THOẠI</label>
                <div class="input-wrapper">
                    <span class="icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M3.654 1.328a.678.678 0 0 0-1.015-.063L1.605 2.3c-.483.484-.661 1.169-.45 1.77a17.6 17.6 0 0 0 4.168 6.608 17.6 17.6 0 0 0 6.608 4.168c.601.211 1.286.033 1.77-.45l1.034-1.034a.678.678 0 0 0-.063-1.015l-2.307-1.794a.68.68 0 0 0-.58-.122l-2.19.547a1.75 1.75 0 0 1-1.657-.459L5.482 8.062a1.75 1.75 0 0 1-.46-1.657l.548-2.19a.68.68 0 0 0-.122-.58z" />
                        </svg>
                    </span>
                    <input type="text" asp-for="txtPhone" placeholder="Số điện thoại">
                </div>
                <span asp-validation-for="txtPhone" class="error-msg" style="color: #ef4444; font-size: 0.85rem; margin-top: 5px; display: block;"></span>
            </div>

            <div class="form-group">
                <label asp-for="txtPassword">MẬT KHẨU</label>
                <div class="input-wrapper">
                    <span class="icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2m3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2M5 8h6a1 1 0 0 1 1 1v5a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V9a1 1 0 0 1 1-1" />
                        </svg>
                    </span>
                    <input type="password" asp-for="txtPassword" id="txtPassword" placeholder="...........">
                    <button type="button" class="icon-btn" onclick="toggleVisibility('txtPassword', 'eye-pw-closed', 'eye-pw-open')">
                        <svg id="eye-pw-closed" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z" />
                            <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0" />
                        </svg>
                        <svg id="eye-pw-open" style="display: none;" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7.028 7.028 0 0 0-2.79.588l.77.771A5.944 5.944 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.134 13.134 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755-.165.165-.337.328-.517.486z" />
                            <path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829" />
                            <path d="M3.35 5.47c-.18.16-.353.322-.518.487A13.134 13.134 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7.029 7.029 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.709zm10.296 8.884-12-12 .708-.708 12 12-.708.708" />
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="txtPassword" class="error-msg" style="color: #ef4444; font-size: 0.85rem; margin-top: 5px; display: block;"></span>
            </div>

            <div class="form-group">
                <label asp-for="txtConfirmPassword">NHẬP LẠI MẬT KHẨU</label>
                <div class="input-wrapper">
                    <span class="icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2m3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2M5 8h6a1 1 0 0 1 1 1v5a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V9a1 1 0 0 1 1-1" />
                        </svg>
                    </span>
                    <input type="password" asp-for="txtConfirmPassword" id="txtConfirmPassword" placeholder="...........">
                    <button type="button" class="icon-btn" onclick="toggleVisibility('txtConfirmPassword', 'eye-cpw-closed', 'eye-cpw-open')">
                        <svg id="eye-cpw-closed" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z" />
                            <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0" />
                        </svg>
                        <svg id="eye-cpw-open" style="display: none;" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7.028 7.028 0 0 0-2.79.588l.77.771A5.944 5.944 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.134 13.134 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755-.165.165-.337.328-.517.486z" />
                            <path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829" />
                            <path d="M3.35 5.47c-.18.16-.353.322-.518.487A13.134 13.134 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7.029 7.029 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.709zm10.296 8.884-12-12 .708-.708 12 12-.708.708" />
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="txtConfirmPassword" class="error-msg" style="color: #ef4444; font-size: 0.85rem; margin-top: 5px; display: block;"></span>
            </div>

            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger" style="color: #ef4444; margin-bottom: 15px; text-align: center; font-size: 0.9rem;">
                    @ViewBag.ErrorMessage
                </div>
            }
            @if (ViewBag.Status != null ||ViewBag.Status == false)
            {
                <div class="alert alert-danger">
                    @ViewBag.Msg
                </div>
            }
            <button type="submit" class="submit-btn">ĐĂNG KÝ</button>

        </form>

        <div class="auth-footer">
            Đã có tài khoản? <a asp-controller="Auth" asp-action="Login">Đăng nhập ngay</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        // Hàm tái sử dụng cho việc ẩn/hiện bất kỳ ô password nào
        function toggleVisibility(inputId, closedIconId, openIconId) {
            const input = document.getElementById(inputId);
            const iconClosed = document.getElementById(closedIconId);
            const iconOpen = document.getElementById(openIconId);

            if (input.type === "password") {
                input.type = "text";
                iconClosed.style.display = "none";
                iconOpen.style.display = "block";
            } else {
                input.type = "password";
                iconClosed.style.display = "block";
                iconOpen.style.display = "none";
            }
        }
    </script>
}