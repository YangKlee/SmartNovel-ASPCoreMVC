@{
    ViewData["Title"] = "Not Found";
}
<style>
    .error-container {
        min-height: 75vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 2rem;
    }
    .error-image {
        width: 100%;
        max-width: 350px;
        border-radius: 12px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
        margin-bottom: 2rem;
        transition: transform 0.3s ease;
    }
    .error-image:hover {
        transform: scale(1.02);
    }
    .error-alert {
        max-width: 600px;
        border-left: 5px solid #6c757d;
        background-color: #f8f9fa;
        color: #495057;
        border-radius: 8px;
        padding: 1.5rem;
        box-shadow: 0 4px 12px rgba(108, 117, 125, 0.1);
    }
    .error-title {
        font-size: 1.5rem;
        font-weight: bold;
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }
</style>

<div class="error-container">
    <img src="https://pub-20056e4912f440f08b3d40eea545f95f.r2.dev/smart-novel/res/0ef9e234ebe01ed98a6d4161f1da24c4_1472302392036695952.webp" alt="Error Image" class="error-image" />
    
    <div class="alert error-alert">
        <div class="error-title">
            <i class="bi bi-question-circle-fill"></i>
            404 - Không tìm thấy trang
        </div>
        <div class="mt-2 text-start text-md-center">
            Xin lỗi, trang bạn đang tìm kiếm không tồn tại, đã bị xóa hoặc đường dẫn không chính xác.
        </div>
        <div class="mt-4 text-center">
            <a href="/" class="btn btn-secondary px-4 py-2 rounded-3 fw-bold">Về trang chủ</a>
        </div>
    </div>
</div>
